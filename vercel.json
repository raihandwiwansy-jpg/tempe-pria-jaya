{
    "version": 2,
    "framework": "laravel",
    "rootDirectory": "public",
    "installCommand": "composer install",
    "builds": [
        {
            "src": "index.php",
            "use": "@vercel/php"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "index.php"
        }
    ]
}